# ============================================================================
# Pramana RAG - Environment Variables Template (.env.docker)
# ============================================================================
#
# IMPORTANT: Do NOT commit this file with real credentials!
# 1. Copy this file to .env.docker
# 2. Fill in your API keys
# 3. Pass to docker: docker-compose -f docker-compose.service.yml --env-file .env.docker up
#
# Or use in docker run:
#   docker run --env-file .env.docker -v ./service/storage:/app/service/storage pramana-rag:1.0.0
#
# ============================================================================

# =============================================================================
# [REQUIRED] Core Storage & Device Configuration
# =============================================================================

# Storage directory where ingested documents are stored
# In Docker: always use /app/service/storage (mounted volume)
POWERMIND_STORAGE_DIR="/app/service/storage"

# Device mode: "api" (default, no GPU needed) or "cuda" (requires GPU + local models)
# - "api": Uses cloud APIs (NVIDIA, Gemini, Mistral) - recommended for most deployments
# - "cuda": Uses local models (Qwen, Qwen-VL) - requires GPU and model files mounted
POWERMIND_DEVICE="api"

# =============================================================================
# [REQUIRED] NVIDIA API - Used for embeddings (core to retrieval)
# =============================================================================

# Get from: https://catalog.ngc.nvidia.com/
# This is the MAIN required API key for the RAG pipeline
NVIDIA_KEY="<your-nvidia-api-key>"

# NVIDIA embedding model (do not change unless you have a reason)
NVIDIA_EMBEDDING_MODEL="nvidia/nv-embed-v1"

# NVIDIA base URL for API calls
NVIDIA_VLM_BASE_URL="https://integrate.api.nvidia.com/v1"

# NVIDIA VLM model (used as fallback for visual page analysis)
NVIDIA_VLM_MODEL="microsoft/phi-4-multimodal-instruct"

# NVIDIA generation model (used for answer generation)
NVIDIA_GENERATION_MODEL="microsoft/phi-4-multimodal-instruct"

# =============================================================================
# [RECOMMENDED] Google Gemini - Used for relevance grading & visual understanding
# =============================================================================

# Get from: https://aistudio.google.com/app/apikey
# At least GEMINI_API_KEY_1 is strongly recommended for relevance scoring
GEMINI_API_KEY_1="<your-gemini-api-key-1>"
GEMINI_API_KEY_2="<optional-gemini-api-key-2>"
GEMINI_API_KEY_3="<optional-gemini-api-key-3>"
GEMINI_API_KEY_4="<optional-gemini-api-key-4>"
GEMINI_API_KEY_5="<optional-gemini-api-key-5>"
GEMINI_API_KEY_6="<optional-gemini-api-key-6>"

# Gemini model for relevance grading
GEMINI_RELEVANCE_MODEL="gemini-2.5-flash"

# =============================================================================
# [OPTIONAL] Mistral AI - Used for OCR on tables and layouts
# =============================================================================

# Get from: https://console.mistral.ai/api-keys/
# Only required if you enable OCR during ingestion (POWERMIND_ENABLE_VISUAL_UNDERSTANDING)
MISTRAL_API_KEY="<your-mistral-api-key>"
MISTRAL_SERVER_URL="https://api.mistral.ai"
MISTRAL_TIMEOUT_MS="120000"

# =============================================================================
# [OPTIONAL] Groq - Alternative LLM for relevance/chunking/generation
# =============================================================================

# Get from: https://console.groq.com/keys
# Only needed if you explicitly choose Groq as provider
GROQ_API_KEY="<your-groq-api-key>"
GROQ_RELEVANCE_MODEL="llama-3.1-8b-instant"
GROQ_GENERATION_MODEL="llama-3.3-70b-versatile"

# =============================================================================
# [OPTIONAL] OpenRouter - Alternative LLM for generation
# =============================================================================

# Get from: https://openrouter.ai/account/api-keys
# Only needed if you explicitly choose OpenRouter as provider
OPEN_ROUTER_API_KEY="<your-openrouter-api-key>"
OPEN_ROUTER_GENERATION_MODEL="liquid/lfm-2.5-1.2b-instruct:free"

# =============================================================================
# Retrieval & Relevance Configuration
# =============================================================================

# Relevance provider: "gemini" (recommended), "groq", or "lexical" (no API call)
POWERMIND_RELEVANCE_PROVIDER="gemini"

# Allow fallback to lexical search if CRAG relevance fails
POWERMIND_ALLOW_LEXICAL_CRAG_FALLBACK="0"

# Enable visual page retrieval (requires ColPali index)
POWERMIND_ENABLE_QUERY_VISUAL_RETRIEVAL="0"

# Enable ColPali visual index during ingestion
POWERMIND_ENABLE_COLPALI_VISUAL_INDEX="0"

# Load imported records from legacy systems
POWERMIND_LOAD_IMPORTED_RECORDS="0"

# =============================================================================
# Ingestion Configuration
# =============================================================================

# Enable visual page understanding during ingestion
# Processes each page with VLM to understand diagrams, tables, layout
POWERMIND_ENABLE_VISUAL_UNDERSTANDING="true"

# Visual understanding provider: "gemini_nvidia" (Gemini primary, NVIDIA fallback)
# or "nvidia_gemini" (NVIDIA primary, Gemini fallback)
POWERMIND_VISUAL_UNDERSTANDING_PROVIDER="gemini_nvidia"

# Refresh visual understanding if re-ingesting (slow, only if needed)
POWERMIND_REFRESH_VISUAL_UNDERSTANDING="0"

# =============================================================================
# Generation Configuration
# =============================================================================

# Generation provider: "nvidia" (default), "gemini", "groq", or "openrouter"
POWERMIND_GENERATION_PROVIDER="nvidia"

# Image provider for visual fallback: "nvidia_gemini" or "gemini_nvidia"
POWERMIND_IMAGE_PROVIDER="nvidia_gemini"

# Enable final VLM page check when no relevant chunks found
POWERMIND_ENABLE_QUERY_VLM_FALLBACK="1"

# Include page images in generated answers
POWERMIND_INCLUDE_PAGE_IMAGES_IN_ANSWERS="0"

# =============================================================================
# Chunking Configuration
# =============================================================================

# Chunking provider: "rules" (default, fast) or "gemini" (LLM-based, more accurate)
POWERMIND_CHUNKING_PROVIDER="rules"

# Chunking fallback if primary fails
POWERMIND_CHUNKING_FALLBACK_PROVIDER="none"

# LLM model for chunking (if POWERMIND_CHUNKING_PROVIDER="gemini")
GEMINI_CHUNKING_MODEL="gemini-2.5-flash"
GROQ_CHUNKING_MODEL="llama-3.3-70b-versatile"

# =============================================================================
# [OPTIONAL] Local Model Paths (only if POWERMIND_DEVICE="cuda")
# =============================================================================

# Paths to local model files (in Docker: mount to /app/models/)
# QWEN_MODEL_PATH="/app/models/Qwen"
# QWEN_VL_MODEL_PATH="/app/models/Qwen_VL"
# QWEN_VL_DEVICE="cuda"
# QWEN_VL_VISUAL_MAX_TOKENS="384"
# POWERMIND_CUDA_ARCH="sm_120"

# =============================================================================
# [OPTIONAL] Verification (experimental feature)
# =============================================================================

# Enable answer verification (checks if generated answer is supported by context)
POWERMIND_ENABLE_VERIFICATION="0"

# Model for verification
LETTUCE_MODEL_PATH="KRLabsOrg/lettucedect-base-modernbert-en-v1"

# =============================================================================
# Python Configuration
# =============================================================================

# Prevent Python from writing bytecode files
PYTHONDONTWRITEBYTECODE="1"

# Force unbuffered output (see container logs in real-time)
PYTHONUNBUFFERED="1"

# =============================================================================
# Debug/Development (optional)
# =============================================================================

# Enable debug logging (verbose output)
# LOG_LEVEL="DEBUG"

# Disable caching for development
# POWERMIND_LOCAL_ONLY="1"
